# Only infrastructure URLs are required here.
# All platform credentials (Plex, Tautulli, TMDB, Sonarr, Radarr)
# are configured via the Settings page in the web UI.

# Database connection string used by the application services.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+asyncpg://mli:mli@db:5432/mli

# Redis connection string used by Celery and the async backend.
# Format: redis://<host>:<port>
REDIS_URL=redis://redis:6379

# PostgreSQL credentials and database name used by the `db` service.
POSTGRES_USER=mli
POSTGRES_PASSWORD=mli
POSTGRES_DB=mli

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------

# Debug mode. Set to True for local development (disables some security checks).
DEBUG=True

# A strong, random secret key (at least 32 characters). Used to sign JWTs and
# to encrypt settings stored in the database. MUST be changed in production.
SECRET_KEY=change-me-to-a-random-string-of-at-least-32-characters

# JWT access token lifetime in minutes. Default: 10080 (7 days).
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Admin username and bcrypt password hash.
# Default hash below is for the password "admin". Generate a new one with:
#   python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('your-password'))"
ADMIN_USERNAME=admin
# $$ is escaped as $ for Docker Compose variable interpolation.
ADMIN_PASSWORD_HASH=$$2b$$12$$yzvdd6qsIPemzshXkqPWJeyqCUhgYZQBlDXyX3VwwxM1R0EPm233W

# Comma-separated list of allowed frontend origins in production (DEBUG=False).
# Example: ALLOWED_ORIGINS=https://mli.example.com,https://admin.example.com
ALLOWED_ORIGINS=
